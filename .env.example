# OneBusAway API key — get one at https://www.pugetsound.onebusaway.org/p/sign-up
OBA_API_KEY=your-api-key-here

# WiFi network names used to auto-detect your current location
# Optional when DEFAULT_LOCATION is set for ethernet/no-WiFi use
HOME_WIFI=MyHomeNetwork
OFFICE_WIFI=MyOfficeNetwork

# OneBusAway stop IDs — you can use a bare stop code from Google Maps/OBA
# or a full OBA stop ID from the API, for example 71335 or 1_71335
HOME_STOP_ID=75403
OFFICE_STOP_ID=71335

# Optional fallback for ethernet/no-WiFi devices
# Must be "home" or "office"
DEFAULT_LOCATION=home
