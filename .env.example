# OneBusAway API key — get one at https://www.pugetsound.onebusaway.org/p/sign-up
OBA_API_KEY=your-api-key-here

# WiFi network names used to auto-detect direction
HOME_WIFI=MyHomeNetwork
OFFICE_WIFI=MyOfficeNetwork

# OneBusAway stop IDs — find yours at https://pugetsound.onebusaway.org
# Example: 1_75403
HOME_STOP_ID=1_75403
OFFICE_STOP_ID=1_12345
